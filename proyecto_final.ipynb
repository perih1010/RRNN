    "        x = x.rotate(rot_deg)\n",
    "        x = np.array(x).astype(np.float32) / 255.0\n",
    "        return x\n",
    "\n",
    "# BLOQUE 6: CREACIÓN DE DATALOADERS (CON Y SIN AUGMENTATION)\n",
